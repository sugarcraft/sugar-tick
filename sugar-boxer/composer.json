{
    "name": "sugarcraft/sugar-boxer",
    "description": "PHP port of treilik/bubbleboxer \u2014 box-drawing layout engine. Compose terminal content into H/V panels with box-drawing borders, padding, and dynamic dimension calculation.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "box",
        "layout",
        "panel",
        "border",
        "terminal",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-boxer",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-boxer/issues",
        "source": "https://github.com/sugarcraft/sugar-boxer"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Boxer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Boxer\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
