        {
            "type": "path",
            "url": "../candy-tetris",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../super-candy",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-crush",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "SugarCraft\\Prompt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Prompt\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
