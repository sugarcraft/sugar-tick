{
    "name": "sugarcraft/sugar-prompt",
    "description": "PHP port of charmbracelet/huh — interactive form library (Note, Input, Confirm, Select, MultiSelect, Text, FilePicker) with multi-page Group support and 6 stock themes.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "cli",
        "form",
        "prompt",
        "input",
        "select",
        "multi-select",
        "confirm",
        "file-picker",
        "huh",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-prompt",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-prompt/issues",
        "source": "https://github.com/sugarcraft/sugar-prompt",
        "docs": "https://sugarcraft.github.io/lib/sugar-prompt.html"
    },
    "require": {
        "php": "^8.1",
        "sugarcraft/candy-core": "@dev",
        "sugarcraft/candy-sprinkles": "@dev",
        "sugarcraft/sugar-bits": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../honey-bounce",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-zone",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-bits",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-charts",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-shell",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-shine",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-kit",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-freeze",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-glow",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-spark",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-wish",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-wishlist",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-metrics",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-mold",
