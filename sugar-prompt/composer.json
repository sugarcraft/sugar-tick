{
    "name": "sugarcraft/sugar-prompt",
    "description": "PHP port of charmbracelet/huh \u2014 interactive form library (Note, Input, Confirm, Select, MultiSelect, Text, FilePicker) with multi-page Group support, 6 stock themes, and form-level KeyMap override per binding.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "cli",
        "form",
        "prompt",
        "input",
        "select",
        "multi-select",
        "confirm",
        "file-picker",
        "huh",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-prompt",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-prompt/issues",
        "source": "https://github.com/sugarcraft/sugar-prompt",
        "docs": "https://sugarcraft.github.io/lib/sugar-prompt.html"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-forms": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "sugarcraft/sugar-bits": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Prompt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Prompt\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-forms",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-bits",
            "options": {
                "symlink": true
            }
        }
    ]
}
