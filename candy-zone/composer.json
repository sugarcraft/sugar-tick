{
    "name": "sugarcraft/candy-zone",
    "description": "PHP port of lrstanley/bubblezone \u2014 mouse zone tracker for TUI apps.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "cli",
        "mouse",
        "zones",
        "click",
        "bubblezone",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-zone",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-zone/issues",
        "source": "https://github.com/sugarcraft/candy-zone",
        "docs": "https://sugarcraft.github.io/lib/candy-zone.html"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "sugarcraft/candy-sprinkles": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Zone\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Zone\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        }
    ]
}
