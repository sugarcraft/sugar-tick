{
    "name": "sugarcraft/candy-zone",
    "description": "PHP port of lrstanley/bubblezone — mouse zone tracker for TUI apps.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "cli",
        "mouse",
        "zones",
        "click",
        "bubblezone",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-zone",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-zone/issues",
        "source": "https://github.com/sugarcraft/candy-zone",
        "docs": "https://sugarcraft.github.io/lib/candy-zone.html"
    },
    "require": {
        "php": "^8.1",
        "sugarcraft/candy-core": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "sugarcraft/candy-sprinkles": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
