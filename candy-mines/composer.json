{
    "name": "sugarcraft/candy-mines",
    "description": "Minesweeper TUI \u2014 port of maxpaulus43/go-sweep on the SugarCraft stack.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "tui",
        "game",
        "minesweeper",
        "sugarcraft",
        "sugarcraft"
    ],
    "homepage": "https://sugarcraft.github.io/lib/candy-mines.html",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-mines/issues",
        "source": "https://github.com/sugarcraft/candy-mines",
        "docs": "https://sugarcraft.github.io/lib/candy-mines.html"
    },
    "bin": [
        "bin/candy-mines"
    ],
    "require": {
        "php": ">=8.3",
        "sugarcraft/candy-buffer": "dev-master",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-mouse": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "sugarcraft/candy-testing": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Mines\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Mines\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-layout",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-buffer",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-mouse",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-testing",
            "options": {
                "symlink": true
            }
        }
    ]
}
