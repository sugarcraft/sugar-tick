{
    "name": "sugarcraft/sugar-stash",
    "description": "Terminal Git client — port of jesseduffield/lazygit on the SugarCraft stack.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "tui",
        "cli",
        "git",
        "lazygit",
        "sugarcraft",
        "sugarcraft"
    ],
    "homepage": "https://sugarcraft.github.io/lib/sugar-stash.html",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-stash/issues",
        "source": "https://github.com/sugarcraft/sugar-stash",
        "docs": "https://sugarcraft.github.io/lib/sugar-stash.html"
    },
    "bin": [
        "bin/sugar-stash"
    ],
    "require": {
        "php": ">=8.1",
        "sugarcraft/candy-core": "@dev",
        "sugarcraft/candy-sprinkles": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Stash\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Stash\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
