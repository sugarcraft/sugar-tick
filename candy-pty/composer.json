{
    "name": "sugarcraft/candy-pty",
    "description": "PHP port of charmbracelet/x/xpty \u2014 pseudo-terminal abstraction (open / spawn / resize) for SugarCraft. Linux + macOS via FFI to libc.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "cli",
        "pty",
        "pseudo-terminal",
        "ffi",
        "libc",
        "posix",
        "xpty",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-pty",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-pty/issues",
        "source": "https://github.com/sugarcraft/candy-pty",
        "docs": "https://sugarcraft.github.io/lib/candy-pty.html"
    },
    "require": {
        "php": "^8.3",
        "ext-ffi": "*",
        "sugarcraft/candy-core": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "suggest": {
        "ext-pcntl": "Enables cleaner SIGCHLD reaping and signal-driven resize forwarding; the lib polls waitpid() when pcntl is absent."
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-core"
        }
    ],
    "autoload": {
        "psr-4": {
            "SugarCraft\\Pty\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Pty\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
