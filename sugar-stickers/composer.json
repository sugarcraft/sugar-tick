{
    "name": "sugarcraft/sugar-stickers",
    "description": "PHP port of 76creates/stickers \u2014 Lipgloss utility components. FlexBox (CSS flexbox-like responsive grid layout) and Table (sortable, filterable data table with column definitions).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "flexbox",
        "table",
        "layout",
        "grid",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-stickers",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-stickers/issues",
        "source": "https://github.com/sugarcraft/sugar-stickers"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/sugar-bits": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Stickers\\": "src/",
            "SugarCraft\\Stickers\\Flex\\": "src/Flex/",
            "SugarCraft\\Stickers\\Table\\": "src/Table/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Stickers\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../sugar-bits",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
