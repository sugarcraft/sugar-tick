{
    "name": "sugarcraft/candy-mosaic",
    "description": "Image-to-cell renderer \u2014 PNG/JPEG/static GIF to terminal via Sixel, Kitty, iTerm2, or half-block Unicode fallback. Port of charmbracelet/x/mosaic.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "image",
        "sixel",
        "kitty",
        "iterm2",
        "charmbracelet",
        "x-mosaic",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-mosaic",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-mosaic/issues",
        "source": "https://github.com/sugarcraft/candy-mosaic",
        "docs": "https://sugarcraft.github.io/lib/candy-mosaic.html"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "ext-gd": "*",
        "ext-mbstring": "*",
        "react/promise": "^3.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../candy-shine",
            "options": { "symlink": true }
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-sprinkles"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/honey-bounce"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-zone"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-bits"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-charts"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-prompt"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-shell"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-shine"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-kit"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-freeze"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-glow"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-spark"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-wish"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-wishlist"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-metrics"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-mold"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-tetris"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/super-candy"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-crush"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-flip"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-stash"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-query"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-tick"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-mines"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/honey-flap"
        }
    ],
    "autoload": {
        "psr-4": {
            "SugarCraft\\Mosaic\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Mosaic\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
