{
    "name": "sugarcraft/sugarcraft",
    "description": "PHP ports of the Charmbracelet TUI ecosystem (umbrella monorepo) — install all 13 libraries at once.",
    "type": "metapackage",
    "license": "MIT",
    "version": "1.0.0",
    "keywords": [
        "tui", "terminal", "cli", "console",
        "bubbletea", "lipgloss", "bubbles", "huh", "gum",
        "glamour", "glow", "freeze", "harmonica", "ntcharts",
        "wish", "wishlist", "ssh", "metrics", "telemetry",
        "sugarcraft"
    ],
    "homepage": "https://github.com/detain/sugarcraft",
    "authors": [
        { "name": "Joe Huss", "email": "detain@interserver.net", "role": "Maintainer" }
    ],
    "support": {
        "issues": "https://github.com/detain/sugarcraft/issues",
        "source": "https://github.com/detain/sugarcraft",
        "docs":   "https://github.com/detain/sugarcraft/blob/master/CONVERSION.md"
    },
    "require": {
        "php": "^8.2",
        "sugarcraft/candy-core":      "dev-master",
        "sugarcraft/candy-vt":        "dev-master",
        "sugarcraft/candy-vcr":       "dev-master",
        "sugarcraft/candy-freeze":    "dev-master",
        "sugarcraft/candy-metrics":   "dev-master",
        "sugarcraft/candy-kit":       "dev-master",
        "sugarcraft/candy-pty":       "dev-master",
        "sugarcraft/candy-shell":     "dev-master",
        "sugarcraft/candy-shine":     "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "sugarcraft/candy-wish":      "dev-master",
        "sugarcraft/candy-zone":      "dev-master",
        "sugarcraft/honey-bounce":    "dev-master",
        "sugarcraft/sugar-bits":      "dev-master",
        "sugarcraft/sugar-charts":    "dev-master",
        "sugarcraft/sugar-glow":      "dev-master",
        "sugarcraft/sugar-prompt":    "dev-master",
        "sugarcraft/sugar-spark":     "dev-master",
        "sugarcraft/sugar-wishlist":  "dev-master"
    },
    "repositories": [
        { "type": "path", "url": "candy-core",      "options": { "symlink": true } },
        { "type": "path", "url": "candy-freeze",    "options": { "symlink": true } },
        { "type": "path", "url": "candy-metrics",   "options": { "symlink": true } },
        { "type": "path", "url": "candy-kit",       "options": { "symlink": true } },
        { "type": "path", "url": "candy-pty",       "options": { "symlink": true } },
        { "type": "path", "url": "candy-shell",     "options": { "symlink": true } },
        { "type": "path", "url": "candy-shine",     "options": { "symlink": true } },
        { "type": "path", "url": "candy-sprinkles", "options": { "symlink": true } },
        { "type": "path", "url": "candy-vt",         "options": { "symlink": true } },
        { "type": "path", "url": "candy-vcr",       "options": { "symlink": true } },
        { "type": "path", "url": "candy-wish",      "options": { "symlink": true } },
        { "type": "path", "url": "candy-zone",      "options": { "symlink": true } },
        { "type": "path", "url": "honey-bounce",    "options": { "symlink": true } },
        { "type": "path", "url": "sugar-bits",      "options": { "symlink": true } },
        { "type": "path", "url": "sugar-charts",    "options": { "symlink": true } },
        { "type": "path", "url": "sugar-glow",      "options": { "symlink": true } },
        { "type": "path", "url": "sugar-prompt",    "options": { "symlink": true } },
        { "type": "path", "url": "sugar-spark",     "options": { "symlink": true } },
        { "type": "path", "url": "sugar-wishlist",  "options": { "symlink": true } },
        { "type": "path", "url": "candy-log",  "options": { "symlink": true } },
        { "type": "path", "url": "candy-palette",  "options": { "symlink": true } },
        { "type": "path", "url": "candy-lister",  "options": { "symlink": true } },
        { "type": "path", "url": "sugar-boxer",  "options": { "symlink": true } },
        { "type": "path", "url": "sugar-veil",  "options": { "symlink": true } },
        { "type": "path", "url": "sugar-crumbs",  "options": { "symlink": true } },
        { "type": "path", "url": "candy-hermit",  "options": { "symlink": true } },
        { "type": "path", "url": "sugar-stickers",  "options": { "symlink": true } },
        { "type": "path", "url": "sugar-toast",  "options": { "symlink": true } },
        { "type": "path", "url": "sugar-calendar",  "options": { "symlink": true } },
        { "type": "path", "url": "sugar-readline",  "options": { "symlink": true } },
        { "type": "path", "url": "sugar-table",  "options": { "symlink": true } },
        { "type": "path", "url": "sugar-skate",  "options": { "symlink": true } },
        { "type": "path", "url": "sugar-post",  "options": { "symlink": true } },
        { "type": "path", "url": "candy-serve",  "options": { "symlink": true } }
    ],
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
