{
    "name": "candycore/candycore",
    "description": "PHP ports of the Charmbracelet TUI ecosystem (umbrella monorepo).",
    "type": "metapackage",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "candycore/candy-core":   "@dev",
        "candycore/candy-gloss":  "@dev",
        "candycore/honey-bounce": "@dev"
    },
    "repositories": [
        { "type": "path", "url": "candy-core",   "options": { "symlink": true } },
        { "type": "path", "url": "candy-gloss",  "options": { "symlink": true } },
        { "type": "path", "url": "honey-bounce", "options": { "symlink": true } }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
