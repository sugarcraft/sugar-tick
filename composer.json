{
    "name": "sugarcraft/sugar-tick",
    "description": "Privacy-first coding-time tracker \u2014 port of Rtarun3606k/TakaTime on the SugarCraft stack.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "tui",
        "cli",
        "time-tracking",
        "wakatime",
        "takatime",
        "sugarcraft",
        "sugarcraft"
    ],
    "homepage": "https://sugarcraft.github.io/lib/sugar-tick.html",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-tick/issues",
        "source": "https://github.com/sugarcraft/sugar-tick",
        "docs": "https://sugarcraft.github.io/lib/sugar-tick.html"
    },
    "bin": [
        "bin/sugar-tick"
    ],
    "require": {
        "php": ">=8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "sugarcraft/sugar-charts": "dev-master"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-charts",
            "options": {
                "symlink": true
            }
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Tick\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Tick\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
