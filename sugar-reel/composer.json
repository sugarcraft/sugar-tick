{
    "name": "sugarcraft/sugar-reel",
    "description": "Terminal video player for SugarCraft — plays mp4 (and more) by decoding frames on the fly and rendering them to ASCII / ANSI / truecolor half-block / sixel / kitty output.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "video",
        "video-player",
        "ascii",
        "ascii-art",
        "ansi",
        "sixel",
        "kitty",
        "ffmpeg",
        "tplay",
        "video-to-ascii",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-reel",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-reel/issues",
        "source": "https://github.com/sugarcraft/sugar-reel",
        "docs": "https://sugarcraft.github.io/lib/sugar-reel.html"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-buffer": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "sugarcraft/candy-palette": "dev-master",
        "sugarcraft/candy-input": "dev-master",
        "sugarcraft/candy-async": "dev-master",
        "sugarcraft/candy-ansi": "dev-master",
        "sugarcraft/candy-mosaic": "dev-master",
        "sugarcraft/candy-flip": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "sugarcraft/candy-testing": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Reel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Reel\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-buffer",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-palette",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-mosaic",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-flip",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-layout",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-pty",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-testing",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
