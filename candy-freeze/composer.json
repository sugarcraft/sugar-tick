{
    "name": "sugarcraft/candy-freeze",
    "description": "PHP port of charmbracelet/freeze \u2014 render code or terminal output to SVG screenshots with macOS-style window controls, drop shadow, line numbers, and inline ANSI SGR colour parsing.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "screenshot",
        "svg",
        "code",
        "terminal",
        "freeze",
        "ansi",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-freeze",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-freeze/issues",
        "source": "https://github.com/sugarcraft/candy-freeze",
        "docs": "https://sugarcraft.github.io/lib/candy-freeze.html"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-ansi": "dev-master",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "sugarcraft/candy-shine": "dev-master"
    },
    "suggest": {
        "ext-gd": "Required for PNG output in PngRenderer"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Freeze\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Freeze\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/candyfreeze"
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-shine",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-layout",
            "options": {
                "symlink": true
            }
        }
    ]
}
