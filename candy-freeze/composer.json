{
    "name": "sugarcraft/candy-freeze",
    "description": "PHP port of charmbracelet/freeze \u2014 render code or terminal output to SVG screenshots with macOS-style window controls, drop shadow, line numbers, and inline ANSI SGR colour parsing.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "screenshot",
        "svg",
        "code",
        "terminal",
        "freeze",
        "ansi",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-freeze",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-freeze/issues",
        "source": "https://github.com/sugarcraft/candy-freeze",
        "docs": "https://sugarcraft.github.io/lib/candy-freeze.html"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "sugarcraft/candy-shine": "dev-master"
    },
    "suggest": {
        "ext-gd": "Required for PNG output in PngRenderer"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-sprinkles"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/honey-bounce"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-zone"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-bits"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-charts"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-prompt"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-shell"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-shine"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-kit"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-glow"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-spark"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-wish"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-wishlist"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-metrics"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-mold"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-tetris"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/super-candy"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-crush"
        }
    ],
    "autoload": {
        "psr-4": {
            "SugarCraft\\Freeze\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Freeze\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/candyfreeze"
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
