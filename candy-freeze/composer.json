{
    "name": "sugarcraft/candy-freeze",
    "description": "PHP port of charmbracelet/freeze — render code or terminal output to SVG screenshots with macOS-style window controls, drop shadow, line numbers, and inline ANSI SGR colour parsing.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "screenshot",
        "svg",
        "code",
        "terminal",
        "freeze",
        "ansi",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-freeze",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-freeze/issues",
        "source": "https://github.com/sugarcraft/candy-freeze",
        "docs": "https://sugarcraft.github.io/lib/candy-freeze.html"
    },
    "require": {
        "php": "^8.1",
        "sugarcraft/candy-core": "@dev",
        "sugarcraft/candy-sprinkles": "@dev",
        "sugarcraft/candy-shine": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../honey-bounce",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-zone",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-bits",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-charts",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-prompt",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-shell",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-shine",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-kit",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-glow",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-spark",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-wish",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-wishlist",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-metrics",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-mold",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-tetris",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../super-candy",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-crush",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "SugarCraft\\Freeze\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Freeze\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/candyfreeze"
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
