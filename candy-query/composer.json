{
    "name": "sugarcraft/candy-query",
    "description": "Terminal SQLite browser \u2014 port of jorgerojas26/lazysql on the SugarCraft stack.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "tui",
        "cli",
        "sql",
        "sqlite",
        "lazysql",
        "sugarcraft",
        "sugarcraft"
    ],
    "homepage": "https://sugarcraft.github.io/lib/candy-query.html",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-query/issues",
        "source": "https://github.com/sugarcraft/candy-query",
        "docs": "https://sugarcraft.github.io/lib/candy-query.html"
    },
    "bin": [
        "bin/candy-query"
    ],
    "require": {
        "php": ">=8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "sugarcraft/sugar-charts": "dev-master",
        "sugarcraft/sugar-table": "dev-master",
        "sugarcraft/sugar-toast": "dev-master",
        "ext-pdo_sqlite": "*",
        "ext-pdo_mysql": "*",
        "ext-pdo_pgsql": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Query\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Query\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-layout",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-table",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-toast",
            "options": {
                "symlink": true
            }
        }
    ]
}
