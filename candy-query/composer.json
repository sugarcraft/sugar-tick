{
    "name": "sugarcraft/candy-query",
    "description": "Terminal SQLite browser \u2014 port of jorgerojas26/lazysql on the SugarCraft stack.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "tui",
        "cli",
        "sql",
        "sqlite",
        "lazysql",
        "sugarcraft",
        "sugarcraft"
    ],
    "homepage": "https://sugarcraft.github.io/lib/candy-query.html",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-query/issues",
        "source": "https://github.com/sugarcraft/candy-query",
        "docs": "https://sugarcraft.github.io/lib/candy-query.html"
    },
    "bin": [
        "bin/candy-query"
    ],
    "require": {
        "php": ">=8.1",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "ext-pdo_sqlite": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Query\\": "src/"
        }
