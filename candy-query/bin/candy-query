#!/usr/bin/env php
<?php

declare(strict_types=1);

(static function () {
    foreach (['vendor/autoload.php', __DIR__ . '/../vendor/autoload.php', __DIR__ . '/../../../autoload.php'] as $candidate) {
        $path = str_starts_with($candidate, '/') ? $candidate : __DIR__ . '/../' . $candidate;
        if (is_file($path)) {
            require $path;
            return;
        }
    }
    fwrite(STDERR, "candy-query: cannot find composer autoload.php\n");
    exit(1);
})();

use CandyCore\Core\Program;
use CandyCore\Core\ProgramOptions;
use CandyCore\Query\App;
use CandyCore\Query\Database;

$argv = $argv ?? [];
$path = $argv[1] ?? null;
if ($path === null) {
    fwrite(STDERR, "usage: candy-query <sqlite-file>\n");
    exit(1);
}

(new Program(App::start(Database::open($path)), new ProgramOptions(useAltScreen: true)))->run();
