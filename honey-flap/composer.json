{
    "name": "sugarcraft/honey-flap",
    "description": "Flappy-Bird-style game \u2014 port of kbrgl/flapioca on the SugarCraft stack.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "tui",
        "game",
        "flappy",
        "honeybounce",
        "physics",
        "sugarcraft",
        "sugarcraft"
    ],
    "homepage": "https://sugarcraft.github.io/lib/honey-flap.html",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/honey-flap/issues",
        "source": "https://github.com/sugarcraft/honey-flap",
        "docs": "https://sugarcraft.github.io/lib/honey-flap.html"
    },
    "bin": [
        "bin/honey-flap"
    ],
    "require": {
        "php": ">=8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "sugarcraft/honey-bounce": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "sugarcraft/candy-testing": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Flap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Flap\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../honey-bounce",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-layout",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-buffer",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-testing",
            "options": {
                "symlink": true
            }
        }
    ]
}
