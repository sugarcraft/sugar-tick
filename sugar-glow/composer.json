{
    "name": "sugarcraft/sugar-glow",
    "description": "PHP port of charmbracelet/glow \u2014 Markdown CLI viewer / pager composing CandyShine + Viewport. 8 stock themes, word-wrap, OSC 8 hyperlinks.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "markdown",
        "viewer",
        "pager",
        "cli",
        "glow",
        "ansi",
        "tui",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-glow",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-glow/issues",
        "source": "https://github.com/sugarcraft/sugar-glow",
        "docs": "https://sugarcraft.github.io/lib/sugar-glow.html"
    },
    "bin": [
        "bin/sugarglow"
    ],
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-shine": "dev-master",
        "sugarcraft/sugar-bits": "dev-master",
        "symfony/console": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "sugarcraft/candy-testing": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Glow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Glow\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-shine",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-bits",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-pty",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-forms",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-zone",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../honey-bounce",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
