{
    "name": "candycore/sugar-tick",
    "description": "Privacy-first coding-time tracker \u2014 port of Rtarun3606k/TakaTime on the SugarCraft stack.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "tui",
        "cli",
        "time-tracking",
        "wakatime",
        "takatime",
        "candycore",
        "sugarcraft"
    ],
    "homepage": "https://sugarcraft.github.io/lib/sugar-tick.html",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-tick/issues",
        "source": "https://github.com/sugarcraft/sugar-tick",
        "docs": "https://sugarcraft.github.io/lib/sugar-tick.html"
    },
    "bin": [
        "bin/sugar-tick"
    ],
    "require": {
        "php": ">=8.1",
        "candycore/candy-core": "@dev",
        "candycore/candy-sprinkles": "@dev",
        "candycore/sugar-charts": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "CandyCore\\Tick\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Tick\\Tests\\": "tests/"
        }
    },
