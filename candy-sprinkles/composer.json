{
    "name": "sugarcraft/candy-sprinkles",
    "description": "PHP port of charmbracelet/lipgloss \u2014 declarative terminal styling and layout.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "cli",
        "lipgloss",
        "ansi",
        "styling",
        "layout",
        "borders",
        "tables",
        "tree",
        "list",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-sprinkles",
