{
    "name": "sugarcraft/candy-sprinkles",
    "description": "PHP port of charmbracelet/lipgloss — declarative terminal styling and layout.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "cli",
        "lipgloss",
        "ansi",
        "styling",
        "layout",
        "borders",
        "tables",
        "tree",
        "list",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-sprinkles",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
