{
    "name": "sugarcraft/sugar-charts",
    "description": "PHP port of NimbleMarkets/ntcharts — terminal charts (canvas, sparkline, bar, line, heatmap, scatter, time-series, OHLC, streamline, waveline) for SugarCraft.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "charts",
        "graphs",
        "sparkline",
        "bar-chart",
        "line-chart",
        "heatmap",
        "scatter",
        "time-series",
        "ohlc",
        "candlestick",
        "ntcharts",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-charts",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-charts/issues",
        "source": "https://github.com/sugarcraft/sugar-charts",
        "docs": "https://sugarcraft.github.io/lib/sugar-charts.html"
    },
    "require": {
        "php": "^8.1",
        "sugarcraft/candy-core": "@dev",
        "sugarcraft/candy-sprinkles": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../honey-bounce",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-zone",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-bits",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-prompt",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-shell",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-shine",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-kit",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-freeze",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-glow",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-spark",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-wish",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-wishlist",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-metrics",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-mold",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-tetris",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../super-candy",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-crush",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "SugarCraft\\Charts\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Charts\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
