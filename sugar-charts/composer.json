{
    "name": "sugarcraft/sugar-charts",
    "description": "PHP port of NimbleMarkets/ntcharts \u2014 terminal charts (canvas, sparkline, bar, line, heatmap, scatter, time-series, OHLC, streamline, waveline) for SugarCraft.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "charts",
        "graphs",
        "sparkline",
        "bar-chart",
        "line-chart",
        "heatmap",
        "scatter",
        "time-series",
        "ohlc",
        "candlestick",
        "ntcharts",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-charts",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-charts/issues",
        "source": "https://github.com/sugarcraft/sugar-charts",
        "docs": "https://sugarcraft.github.io/lib/sugar-charts.html"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-buffer": "dev-master",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "sugarcraft/sugar-dash": "dev-master"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../sugar-dash",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-buffer",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-layout",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-testing",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "sugarcraft/candy-testing": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Charts\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Charts\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
