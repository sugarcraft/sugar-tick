{
    "name": "sugarcraft/candy-wish",
    "description": "SSH server middleware framework — port of charmbracelet/wish. Build TUIs that anyone can `ssh user@host` to run, with composable middleware (auth, logging, rate-limiting, ext-ssh2 client wrappers, mount a SugarCraft Program).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "sugarcraft",
        "wish",
        "ssh",
        "server",
        "middleware",
        "tui",
        "charm",
        "remote",
        "openssh"
    ],
    "homepage": "https://github.com/sugarcraft/candy-wish",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-wish/issues",
        "source": "https://github.com/sugarcraft/candy-wish",
        "docs": "https://sugarcraft.github.io/lib/candy-wish.html"
    },
    "require": {
        "php": ">=8.1",
        "sugarcraft/candy-core": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "ext-ssh2": "Enables the Ssh2 client middleware (forwarding, sftp helpers)."
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Wish\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Wish\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
