{
    "name": "sugarcraft/candy-wish",
    "description": "SSH server middleware framework \u2014 port of charmbracelet/wish. Build TUIs that anyone can `ssh user@host` to run, with composable middleware (auth, logging, rate-limiting, ext-ssh2 client wrappers, mount a SugarCraft Program).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "sugarcraft",
        "wish",
        "ssh",
        "server",
        "middleware",
        "tui",
        "charm",
        "remote",
        "openssh"
    ],
    "homepage": "https://github.com/sugarcraft/candy-wish",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-wish/issues",
        "source": "https://github.com/sugarcraft/candy-wish",
        "docs": "https://sugarcraft.github.io/lib/candy-wish.html"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-pty": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "suggest": {
        "ext-ssh2": "Enables the Ssh2 client middleware (forwarding, sftp helpers)."
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Wish\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Wish\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-pty",
            "options": {"symlink": true}
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-pty"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-sprinkles"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/honey-bounce"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-zone"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-bits"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-charts"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-prompt"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-shell"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-shine"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-kit"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-freeze"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-glow"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-spark"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-wishlist"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-metrics"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-mold"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-tetris"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/super-candy"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-crush"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
