{
    "name": "sugarcraft/sugar-veil",
    "description": "PHP port of rmhubbert/bubbletea-overlay \u2014 modal/overlay compositing for terminal UIs. Composite foreground content over a background at any position (Top/Right/Bottom/Left/Center) with optional pixel offsets.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "overlay",
        "modal",
        "composite",
        "terminal",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-veil",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-veil/issues",
        "source": "https://github.com/sugarcraft/sugar-veil"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "sugarcraft/candy-zone": "dev-master",
        "sugarcraft/honey-bounce": "dev-master"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-zone",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../honey-bounce",
            "options": {
                "symlink": true
            }
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Veil\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Veil\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
