# Render with: vhs sugar-bits/.vhs/tree.tape
Output .vhs/tree.gif

Set FontSize 14
Set Width 720
Set Height 380
Set TypingSpeed 60ms
Set Theme "TokyoNight"

Type "php examples/tree.php"
Enter
Sleep 1s

# Walk the tree: expand, descend, collapse, jump-to-bottom, jump-to-top.
Enter
Sleep 600ms
Down
Sleep 400ms
Down
Sleep 400ms
Enter
Sleep 600ms
Down
Sleep 400ms
Down
Sleep 400ms
Right
Sleep 600ms
Down
Sleep 400ms
Type "G"
Sleep 600ms
Type "g"
Sleep 600ms
Type "q"
