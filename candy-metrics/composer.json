{
    "name": "sugarcraft/candy-metrics",
    "description": "Telemetry primitives for SugarCraft / CandyWish — counters, gauges, histograms with pluggable backends (in-memory, StatsD UDP, Prometheus textfile, JSON stream). Drop-in middleware for SSH session metrics.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "sugarcraft",
        "metrics",
        "telemetry",
        "observability",
        "prometheus",
        "statsd",
        "counter",
        "histogram",
        "ssh",
        "wish"
    ],
    "homepage": "https://github.com/sugarcraft/candy-metrics",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-metrics/issues",
        "source": "https://github.com/sugarcraft/candy-metrics",
        "docs": "https://sugarcraft.github.io/lib/candy-metrics.html"
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "sugarcraft/candy-wish": "@dev"
    },
    "suggest": {
        "sugarcraft/candy-wish": "Required to use the SessionMetrics middleware."
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Metrics\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Metrics\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
