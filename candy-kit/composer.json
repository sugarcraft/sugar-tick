{
    "name": "sugarcraft/candy-kit",
    "description": "PHP port of charmbracelet/fang — opinionated CLI presentation helpers: StatusLine (\u2713/\u2717/\u26a0/\u2139), Banner, Section header, Stage step, HelpText page, and 6 stock themes (ansi/plain/charm/dracula/nord/catppuccin).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "cli",
        "console",
        "presentation",
        "status-line",
        "banner",
        "help",
        "fang",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-kit",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-kit/issues",
        "source": "https://github.com/sugarcraft/candy-kit",
        "docs": "https://sugarcraft.github.io/lib/candy-kit.html"
    },
    "require": {
        "php": "^8.1",
        "sugarcraft/candy-core": "@dev",
        "sugarcraft/candy-sprinkles": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
