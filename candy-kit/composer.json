            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-glow",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-spark",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-wish",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-wishlist",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-metrics",
            "options": {
