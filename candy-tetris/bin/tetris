#!/usr/bin/env php
<?php

declare(strict_types=1);

(static function () {
    foreach (['vendor/autoload.php', __DIR__ . '/../vendor/autoload.php', __DIR__ . '/../../../autoload.php'] as $candidate) {
        $path = str_starts_with($candidate, '/') ? $candidate : __DIR__ . '/../' . $candidate;
        if (is_file($path)) {
            require $path;
            return;
        }
    }
    fwrite(STDERR, "tetris: cannot find composer autoload.php\n");
    exit(1);
})();

use SugarCraft\Core\Program;
use SugarCraft\Core\ProgramOptions;
use SugarCraft\Tetris\Game;
use SugarCraft\Tetris\VsGame;

$mode = 'single';
if ($argc > 1) {
    if ($argv[1] === 'v' || $argv[1] === '--vs') {
        $mode = 'vs';
    } elseif ($argv[1] === 'h' || $argv[1] === '--help') {
        fwrite(STDOUT, "candy-tetris - Tetris clone\n\n");
        fwrite(STDOUT, "Usage: tetris [options]\n");
        fwrite(STDOUT, "  (no args)   Start single player game\n");
        fwrite(STDOUT, "  -v, --vs    Start VS Computer mode\n");
        fwrite(STDOUT, "  -h, --help  Show this help\n");
        exit(0);
    }
}

$game = match ($mode) {
    'vs' => VsGame::start(),
    default => Game::start(),
};

$options = new ProgramOptions(useAltScreen: true);
(new Program($game, $options))->run();
