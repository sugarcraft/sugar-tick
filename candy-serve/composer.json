{
    "name": "sugarcraft/candy-serve",
    "description": "PHP port of charmbracelet/soft-serve \u2014 self-hostable Git server over SSH, Git daemon, and HTTP. Supports user management via SSH public keys, repo access control (public/private), collaborators, on-demand repo creation, Git LFS, and an SSH-accessible TUI for browsing repos/files/commits.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "git",
        "git-server",
        "self-hosted",
        "ssh",
        "lfs",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-serve",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-serve/issues",
        "source": "https://github.com/sugarcraft/candy-serve"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-async": "dev-master",
        "sugarcraft/candy-core": "dev-master",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-ssh2": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Serve\\": "src/",
            "SugarCraft\\Serve\\SSH\\": "src/SSH/",
            "SugarCraft\\Serve\\Git\\": "src/Git/",
            "SugarCraft\\Serve\\LFS\\": "src/LFS/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Serve\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/soft-serve"
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "serve": "php bin/soft-serve serve"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        }
    ]
}
