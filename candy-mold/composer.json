{
    "name": "sugarcraft/candy-mold",
    "description": "Skeleton repo for bootstrapping a SugarCraft TUI app \u2014 `composer create-project sugarcraft/candy-mold my-app`. Ships a runnable counter Model wired through Program, plus a docs-as-code walkthrough that maps every file to the concept it demonstrates.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "sugarcraft",
        "mold",
        "template",
        "skeleton",
        "starter",
        "bootstrap",
        "tui",
        "create-project"
    ],
    "homepage": "https://github.com/sugarcraft/candy-mold",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-mold/issues",
        "source": "https://github.com/sugarcraft/candy-mold",
        "docs": "https://sugarcraft.github.io/lib/candy-mold.html"
    },
    "bin": [
        "bin/start"
    ],
    "require": {
        "php": ">=8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-sprinkles"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/honey-bounce"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-zone"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-bits"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-charts"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-prompt"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-shell"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-shine"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-kit"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-freeze"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-glow"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-spark"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-wish"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-wishlist"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-metrics"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-tetris"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/super-candy"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/sugar-crush"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
