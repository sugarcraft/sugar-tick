#!/usr/bin/env php
<?php

/**
 * `start` — entry point for the bootstrapped SugarCraft app.
 *
 * Replace the `Counter` import below with your own Model once you've
 * forked this template. The Program harness (event loop, render
 * tick, signal handling, raw-mode setup, alt-screen lifecycle) is
 * production-ready out of the box — you just write the Model.
 * Supports an opt-in panic handler via `Log::installPanicHandler()`
 * (uncomment in bootstrap).
 */

declare(strict_types=1);

(static function () {
    foreach (['vendor/autoload.php', __DIR__ . '/../vendor/autoload.php'] as $candidate) {
        $path = str_starts_with($candidate, '/') ? $candidate : __DIR__ . '/../' . $candidate;
        if (is_file($path)) {
            require $path;
            return;
        }
    }
    fwrite(STDERR, "candy-template: cannot find composer autoload.php — did you `composer install`?\n");
    exit(1);
})();

// -----------------------------------------------------------------------
// OPT-IN: Panic handler — uncomment to catch uncaught exceptions and
// display a styled backtrace on crash.  Run `composer require
// sugarcraft/candy-log` first; in a monorepo add a path-repo to
// composer.json repositories[] as well.
// -----------------------------------------------------------------------
// use SugarCraft\Log\Log;
// Log::installPanicHandler();

use App\Counter;
use SugarCraft\Core\Program;

(new Program(new Counter()))->run();
