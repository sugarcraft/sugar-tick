#!/usr/bin/env php
<?php

/**
 * `start` — entry point for the bootstrapped CandyCore app.
 *
 * Replace the `Counter` import below with your own Model once you've
 * forked this template. The Program harness (event loop, render
 * tick, signal handling, raw-mode setup, alt-screen lifecycle) is
 * production-ready out of the box — you just write the Model.
 */

declare(strict_types=1);

(static function () {
    foreach (['vendor/autoload.php', __DIR__ . '/../vendor/autoload.php'] as $candidate) {
        $path = str_starts_with($candidate, '/') ? $candidate : __DIR__ . '/../' . $candidate;
        if (is_file($path)) {
            require $path;
            return;
        }
    }
    fwrite(STDERR, "candy-template: cannot find composer autoload.php — did you `composer install`?\n");
    exit(1);
})();

use App\Counter;
use CandyCore\Core\Program;

(new Program(new Counter()))->run();
