{
    "name": "candycore/honey-bounce",
    "description": "PHP port of charmbracelet/harmonica — damped spring physics for animation.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "CandyCore\\Bounce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Bounce\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
