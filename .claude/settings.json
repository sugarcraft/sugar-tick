{
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/my/.nvm/versions/node/v24.15.0/bin/caliber learn finalize --auto",
            "description": "Caliber: finalizing session learnings"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/my/.nvm/versions/node/v24.15.0/bin/caliber learn observe",
            "description": "Caliber: recording tool usage for session learning"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/my/.nvm/versions/node/v24.15.0/bin/caliber learn observe --failure",
            "description": "Caliber: recording tool failure for session learning"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/my/.nvm/versions/node/v24.15.0/bin/caliber learn observe --prompt",
            "description": "Caliber: recording user prompt for correction detection"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/caliber-check-sync.sh",
            "description": "Caliber: offer setup if not configured"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git *)"
    ]
  }
}