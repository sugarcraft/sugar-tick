{
    "name": "sugarcraft/sugar-gallery",
    "description": "Poster grids and rails for media TUIs \u2014 a 2-D virtualized PosterGrid with sparse range paging, a horizontal Rail carousel, and a PosterCard tile. Renderer-agnostic (holds pre-rendered poster cells).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "grid",
        "gallery",
        "poster",
        "carousel",
        "virtualization",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-gallery",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-gallery/issues",
        "source": "https://github.com/sugarcraft/sugar-gallery",
        "docs": "https://sugarcraft.github.io/lib/sugar-gallery.html"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "sugarcraft/candy-zone": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Gallery\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Gallery\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-zone",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-layout",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-pty",
            "options": {
                "symlink": true
            }
        }
    ]
}
