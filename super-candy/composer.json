{
    "name": "sugarcraft/super-candy",
    "description": "Dual-pane terminal file manager built on the SugarCraft stack. Inspired by superfile and Midnight Commander. Navigate two directories side-by-side, sort by name / mtime / size, multi-select, delete with confirmation, swap focus with Tab.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "sugarcraft",
        "supercandy",
        "superfile",
        "file-manager",
        "tui",
        "dual-pane",
        "midnight-commander"
    ],
    "homepage": "https://github.com/sugarcraft/super-candy",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/super-candy/issues",
        "source": "https://github.com/sugarcraft/super-candy",
        "docs": "https://sugarcraft.github.io/lib/super-candy.html"
    },
    "bin": [
        "bin/supercandy"
    ],
    "require": {
        "php": ">=8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "sugarcraft/candy-mosaic": "dev-master",
        "react/promise": "^3.3"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-mosaic",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-layout",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\SuperCandy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\SuperCandy\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
