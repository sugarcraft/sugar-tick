{
    "name": "sugarcraft/sugar-spark",
    "description": "PHP port of charmbracelet/sequin \u2014 ANSI escape-sequence inspector. Decodes SGR / CSI / OSC / DCS / APC / SS3 sequences into human-readable labels.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ansi",
        "escape",
        "inspector",
        "debug",
        "sequin",
        "tui",
        "terminal",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-spark",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-spark/issues",
        "source": "https://github.com/sugarcraft/sugar-spark",
        "docs": "https://sugarcraft.github.io/lib/sugar-spark.html"
    },
    "bin": [
        "bin/sugarspark"
    ],
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-ansi": "dev-master",
        "sugarcraft/candy-core": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Spark\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Spark\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        }
    ]
}
