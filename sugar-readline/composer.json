{
    "name": "sugarcraft/sugar-readline",
    "description": "PHP port of erikgeiser/promptkit \u2014 interactive line-editing prompt library. Supports text input with validation/completion/hidden-password mode, selection prompts with filtering/pagination/cursor navigation, confirmation prompts, and textarea multi-line input.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "prompt",
        "readline",
        "input",
        "selection",
        "interactive",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-readline",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-readline/issues",
        "source": "https://github.com/sugarcraft/sugar-readline"
    },
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
