parameters:
	ignoreErrors:
		-
			message: '#^Using nullsafe property access "\?\-\>id" on left side of \?\? is unnecessary\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 2
			path: src/Cell/Cell.php

		-
			message: '#^Using nullsafe property access on non\-nullable type SugarCraft\\Vt\\Sgr\\Sgr\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 2
			path: src/Cell/Cell.php

		-
			message: '#^Parameter &\$pending by\-ref type of method SugarCraft\\Vt\\Handler\\EraseHandler\:\:apply\(\) expects array\<int, array\{row\: int, col\: int, cell\: SugarCraft\\Vt\\Cell\\Cell\}\>\|null, array\|null given\.$#'
			identifier: parameterByRef.type
			count: 5
			path: src/Handler/EraseHandler.php

		-
			message: '#^PHPDoc tag @implements has invalid value \(Msg\)\: Unexpected token "\\n ", expected ''\<'' at offset 125 on line 6$#'
			identifier: phpDoc.parseError
			count: 1
			path: src/Msg/FocusInMsg.php

		-
			message: '#^PHPDoc tag @implements has invalid value \(Msg\)\: Unexpected token "\\n ", expected ''\<'' at offset 123 on line 6$#'
			identifier: phpDoc.parseError
			count: 1
			path: src/Msg/FocusOutMsg.php

		-
			message: '#^PHPDoc tag @param has invalid value \(array\<int, array\<int, Cell\>\>\)\: Unexpected token "\*/", expected variable at offset 40 on line 1$#'
			identifier: phpDoc.parseError
			count: 1
			path: src/Screen/Screen.php

		-
			message: '#^Property SugarCraft\\Vt\\Terminal\\Terminal\:\:\$scrollbackSize is never read, only written\.$#'
			identifier: property.onlyWritten
			count: 1
			path: src/Terminal/Terminal.php

		-
			message: '#^Call to method PHPUnit\\Framework\\Assert\:\:assertSame\(\) with ''SugarCraft\\\\Vt\\\\Sgr\\\\Sgr'' and ''SugarCraft\\\\Vt\\\\Sgr\\\\Sgr'' will always evaluate to true\.$#'
			identifier: method.alreadyNarrowedType
			count: 1
			path: tests/CellTest.php

		-
			message: '#^Call to method PHPUnit\\Framework\\Assert\:\:assertTrue\(\) with true will always evaluate to true\.$#'
			identifier: method.alreadyNarrowedType
			count: 1
			path: tests/FuzzerTest.php

		-
			message: '#^Method SugarCraft\\Vt\\Tests\\FuzzerTest\:\:seedAndLength\(\) should return list\<array\{int, int\}\> but returns array\{tiny\: array\{42, 100\}, small\: array\{12648430, 1024\}, medium\: array\{3735928559, 16384\}, large\: array\{195948557, 102400\}\}\.$#'
			identifier: return.type
			count: 1
			path: tests/FuzzerTest.php

		-
			message: '#^Method SugarCraft\\Vt\\Tests\\Mode\\CursorShapeTest\:\:feed\(\) is unused\.$#'
			identifier: method.unused
			count: 1
			path: tests/Mode/CursorShapeTest.php

		-
			message: '#^Call to method PHPUnit\\Framework\\Assert\:\:assertInstanceOf\(\) with ''SugarCraft\\\\Vt\\\\Msg\\\\FocusInMsg'' and SugarCraft\\Vt\\Msg\\FocusInMsg will always evaluate to true\.$#'
			identifier: method.alreadyNarrowedType
			count: 1
			path: tests/Mode/FocusEventTest.php

		-
			message: '#^Call to method PHPUnit\\Framework\\Assert\:\:assertInstanceOf\(\) with ''SugarCraft\\\\Vt\\\\Msg\\\\FocusOutMsg'' and SugarCraft\\Vt\\Msg\\FocusOutMsg will always evaluate to true\.$#'
			identifier: method.alreadyNarrowedType
			count: 1
			path: tests/Mode/FocusEventTest.php

		-
			message: '#^Method SugarCraft\\Vt\\Tests\\Mode\\OriginModeTest\:\:feed\(\) is unused\.$#'
			identifier: method.unused
			count: 1
			path: tests/Mode/OriginModeTest.php
