{
    "name": "sugarcraft/candy-flip",
    "description": "ASCII GIF viewer \u2014 port of namzug16/gifterm on the SugarCraft stack.",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "tui",
        "cli",
        "gif",
        "ascii-art",
        "gifterm",
        "sugarcraft",
        "sugarcraft"
    ],
    "homepage": "https://sugarcraft.github.io/lib/candy-flip.html",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-flip/issues",
        "source": "https://github.com/sugarcraft/candy-flip",
        "docs": "https://sugarcraft.github.io/lib/candy-flip.html"
    },
    "bin": [
        "bin/candy-flip"
    ],
    "require": {
        "php": ">=8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-pty": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "ext-gd": "*"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-pty",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-layout",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Flip\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Flip\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
