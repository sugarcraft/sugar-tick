{
    "name": "sugarcraft/sugar-skate",
    "description": "PHP port of charmbracelet/skate \u2014 a personal key/value store with multi-database support, binary data, and glob/list filtering.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "key-value",
        "store",
        "database",
        "sqlite",
        "skate",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-skate",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-skate/issues",
        "source": "https://github.com/sugarcraft/sugar-skate"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master",
        "ext-sqlite3": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Skate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Skate\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": [
        "bin/skate"
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        }
    ]
}
