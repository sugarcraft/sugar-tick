{
    "name": "sugarcraft/sugar-post",
    "description": "PHP port of charmbracelet/pop \u2014 send emails from PHP via Resend API or direct SMTP. Compose from stdin, attach files, supports CC/BCC, HTML body.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "email",
        "smtp",
        "resend",
        "mailer",
        "send",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-post",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-post/issues",
        "source": "https://github.com/sugarcraft/sugar-post"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-async": "dev-master",
        "sugarcraft/candy-core": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Post\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Post\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": [
        "bin/pop"
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        }
    ]
}
