{
    "name": "sugarcraft/sugar-post",
    "description": "PHP port of charmbracelet/pop \u2014 send emails from PHP via Resend API or direct SMTP. Compose from stdin, attach files, supports CC/BCC, HTML body.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "email",
        "smtp",
        "resend",
        "mailer",
        "send",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-post",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-post/issues",
        "source": "https://github.com/sugarcraft/sugar-post"
    },
    "require": {
        "php": "^8.1",
        "sugarcraft/candy-core": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-sprinkles"
        },
        {
