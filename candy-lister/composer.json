{
    "name": "sugarcraft/candy-lister",
    "description": "PHP port of treilik/bubblelister \u2014 tree-list view component with customisable prefix/suffix rendering, line wrapping, cursor navigation, and per-item styling hooks.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "list",
        "tree",
        "bubble",
        "terminal",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-lister",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-lister/issues",
        "source": "https://github.com/sugarcraft/candy-lister"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-core"
        },
        {
