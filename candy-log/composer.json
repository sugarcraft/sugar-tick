{
    "name": "sugarcraft/candy-log",
    "description": "PHP port of charmbracelet/log \u2014 minimal, colorful leveled logging with structured human-readable output, text/JSON/logfmt formatters, and stdlog adapter.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "logging",
        "cli",
        "console",
        "colorful",
        "structured",
        "log",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-log",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-log/issues",
        "source": "https://github.com/sugarcraft/candy-log"
    },
    "require": {
        "php": "^8.3",
        "psr/log": "^3.0",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-palette": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-palette",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-layout",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Log\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Log\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
