{
    "name": "sugarcraft/candy-hermit",
    "description": "PHP port of Genekkion/theHermit \u2014 fuzzy finder / quick-fix overlay for terminal UIs. Wraps a background view, renders a filterable list overlay on top, background continues to update underneath.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "fuzzy",
        "finder",
        "overlay",
        "quickfix",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-hermit",
