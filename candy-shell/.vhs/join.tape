Output .vhs/join.gif
Set FontSize 14
Set Width 800
Set Height 280
Set TypingSpeed 60ms
Set Theme "TokyoNight"
Type "./bin/candyshell join --horizontal --separator '   ' '  one  ' '  two  ' '  three  '"
Enter
Sleep 1500ms
Type "./bin/candyshell join --vertical 'top'  'middle' 'bottom'"
Enter
Sleep 1500ms
