{
    "name": "candycore/candy-shell",
    "description": "PHP port of charmbracelet/gum — composer-installable CLI of CandyCore TUI primitives.",
    "type": "library",
    "license": "MIT",
    "bin": ["bin/candyshell"],
    "require": {
        "php": "^8.1",
        "candycore/candy-core":      "@dev",
        "candycore/candy-sprinkles": "@dev",
        "candycore/sugar-bits":      "@dev",
        "candycore/sugar-prompt":    "@dev",
        "symfony/console":           "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        { "type": "path", "url": "../candy-core",      "options": { "symlink": true } },
        { "type": "path", "url": "../candy-sprinkles", "options": { "symlink": true } },
        { "type": "path", "url": "../sugar-bits",      "options": { "symlink": true } },
        { "type": "path", "url": "../sugar-prompt",    "options": { "symlink": true } }
    ],
    "autoload": {
        "psr-4": {
            "CandyCore\\Shell\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Shell\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
