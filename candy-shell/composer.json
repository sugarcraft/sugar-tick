{
    "name": "sugarcraft/candy-shell",
    "description": "PHP port of charmbracelet/gum \u2014 composer-installable CLI of SugarCraft TUI primitives. 13 subcommands: choose, confirm, file, filter, format, input, join, log, pager, spin, style, table, write.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "cli",
        "shell",
        "gum",
        "prompt",
        "select",
        "confirm",
        "spinner",
        "filter",
        "style",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-shell",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-shell/issues",
        "source": "https://github.com/sugarcraft/candy-shell",
        "docs": "https://sugarcraft.github.io/lib/candy-shell.html"
    },
    "bin": [
        "bin/candyshell"
    ],
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-forms": "dev-master",
        "sugarcraft/candy-fuzzy": "dev-master",
        "sugarcraft/candy-pty": "dev-master",
        "sugarcraft/candy-shine": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "symfony/console": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Shell\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Shell\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-forms",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-pty",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-shine",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-buffer",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-fuzzy",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-layout",
            "options": {
                "symlink": true
            }
        }
    ]
}
