{
    "name": "sugarcraft/candy-shell",
    "description": "PHP port of charmbracelet/gum — composer-installable CLI of SugarCraft TUI primitives. 13 subcommands: choose, confirm, file, filter, format, input, join, log, pager, spin, style, table, write.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "cli",
        "shell",
        "gum",
        "prompt",
        "select",
        "confirm",
        "spinner",
        "filter",
        "style",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-shell",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-shell/issues",
        "source": "https://github.com/sugarcraft/candy-shell",
        "docs": "https://sugarcraft.github.io/lib/candy-shell.html"
    },
    "bin": [
        "bin/candyshell"
    ],
    "require": {
        "php": "^8.1",
        "sugarcraft/candy-core": "@dev",
        "sugarcraft/candy-shine": "@dev",
        "sugarcraft/candy-sprinkles": "@dev",
        "sugarcraft/sugar-bits": "@dev",
        "sugarcraft/sugar-prompt": "@dev",
        "symfony/console": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../honey-bounce",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-zone",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-bits",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-charts",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-prompt",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-shine",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-kit",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-freeze",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-glow",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-spark",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-wish",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-wishlist",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-metrics",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-mold",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-tetris",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../super-candy",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-crush",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "SugarCraft\\Shell\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Shell\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
