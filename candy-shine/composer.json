{
    "name": "sugarcraft/candy-shine",
    "description": "PHP port of charmbracelet/glamour \u2014 Markdown \u2192 ANSI renderer with word-wrap, OSC 8 hyperlinks, syntax highlighting, and 8 stock themes (ansi/plain/dark/light/notty/dracula/tokyo-night/pink).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "markdown",
        "renderer",
        "ansi",
        "tui",
        "terminal",
        "glamour",
        "commonmark",
        "syntax-highlighting",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-shine",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-shine/issues",
        "source": "https://github.com/sugarcraft/candy-shine",
        "docs": "https://sugarcraft.github.io/lib/candy-shine.html"
    },
    "require": {
        "php": "^8.3",
        "sugarcraft/candy-buffer": "dev-master",
        "sugarcraft/candy-core": "dev-master",
        "sugarcraft/candy-sprinkles": "dev-master",
        "league/commonmark": "^2.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "sugarcraft/candy-testing": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "SugarCraft\\Shine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Shine\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../candy-buffer",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-layout",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-async",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-testing",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-ansi",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-input",
            "options": {
                "symlink": true
            }
        }
    ]
}
