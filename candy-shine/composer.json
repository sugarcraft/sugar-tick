{
    "name": "sugarcraft/candy-shine",
    "description": "PHP port of charmbracelet/glamour — Markdown \u2192 ANSI renderer with word-wrap, OSC 8 hyperlinks, syntax highlighting, and 8 stock themes (ansi/plain/dark/light/notty/dracula/tokyo-night/pink).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "markdown",
        "renderer",
        "ansi",
        "tui",
        "terminal",
        "glamour",
        "commonmark",
        "syntax-highlighting",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-shine",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-shine/issues",
        "source": "https://github.com/sugarcraft/candy-shine",
        "docs": "https://sugarcraft.github.io/lib/candy-shine.html"
    },
    "require": {
        "php": "^8.1",
        "sugarcraft/candy-core": "@dev",
        "sugarcraft/candy-sprinkles": "@dev",
        "league/commonmark": "^2.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../candy-core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-sprinkles",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../honey-bounce",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-zone",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-bits",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-charts",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-prompt",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-shell",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-kit",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-freeze",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-glow",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-spark",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-wish",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-wishlist",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-metrics",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-mold",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../candy-tetris",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../super-candy",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../sugar-crush",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "SugarCraft\\Shine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Shine\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
