{
    "name": "sugarcraft/candy-vcr",
    "description": "Record and replay candy-core Program sessions into cassettes \u2014 bug-repro / regression / fuzzing.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "tui",
        "terminal",
        "ansi",
        "vcr",
        "record",
        "replay",
        "cassette",
        "sugarcraft"
    ],
    "homepage": "https://github.com/sugarcraft/candy-vcr",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/candy-vcr/issues",
        "source": "https://github.com/sugarcraft/candy-vcr",
        "docs": "https://sugarcraft.github.io/lib/candy-vcr.html"
    },
    "require": {
        "php": "^8.2",
        "sugarcraft/candy-core": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "sugarcraft/candy-vt": "dev-master",
        "symfony/yaml": "^6.4 || ^7.0"
    },
    "suggest": {
        "sugarcraft/candy-vt": "Enables ScreenAssertion for cell-grid frame comparison; ByteAssertion is used otherwise.",
        "symfony/yaml": "Enables YamlFormat for human-readable cassettes (test fixtures, hand-written replays); JsonlFormat is the primary format."
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-sprinkles"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-vt"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/honey-bounce"
        },
        {
            "type": "vcs",
            "url": "https://github.com/sugarcraft/candy-zone"
        }
    ],
    "autoload": {
        "psr-4": {
            "SugarCraft\\Vcr\\": "src/"
        }
    },
    "bin": [
        "bin/candy-vcr"
    ],
    "autoload-dev": {
        "psr-4": {
            "SugarCraft\\Vcr\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
